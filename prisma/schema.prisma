generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String     @id @default(uuid())
  anonymous_username String     @unique
  display_name       String?    // Optional, shown to friends
  avatar_species     String     @default("Fox") // Fox, Wolf, Cat, Dragon, Owl, Rabbit
  last_login_date          String?
  login_streak             Int        @default(0)
  current_device_id        String?
  has_completed_onboarding Boolean    @default(false)
  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt

  logs               Log[]
  posts              Post[]
  insights           Insight[]
  wrappedReports     WrappedReport[]
  communities        CommunityMember[]
  
  // New social relations
  puffs              Puff[]
  insightReactions   InsightReaction[]
  replies            Reply[]
  messages           Message[]
  sentRequests       Friendship[] @relation("FriendshipSender")
  receivedRequests   Friendship[] @relation("FriendshipReceiver")
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
}

model Community {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  type        String   @default("Public") // Public, Private
  created_at  DateTime @default(now())
  
  members     CommunityMember[]
  messages    Message[]
}

model CommunityMember {
  id           String    @id @default(uuid())
  userId       String
  communityId  String
  joined_at    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community    Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model Post {
  id          String    @id @default(uuid())
  authorId    String
  content     String
  audience    String    @default("PUBLIC") // PUBLIC, FRIENDS
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  // Social interactions
  puffs            Puff[]
  insightReactions InsightReaction[]
  replies          Reply[]
  notifications    Notification[]
}

model Puff {
  id         String   @id @default(uuid())
  userId     String
  postId     String
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model InsightReaction {
  id         String   @id @default(uuid())
  userId     String
  postId     String
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Reply {
  id         String   @id @default(uuid())
  content    String
  userId     String
  postId     String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(uuid())
  content     String
  userId      String
  communityId String
  created_at  DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
}

model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  sender     User     @relation("FriendshipSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Notification {
  id            String   @id @default(uuid())
  userId        String   // Receiver
  actorId       String?  // Who caused it
  type          String   // PUFF, INSIGHT, REPLY, FRIEND_REQUEST
  content       String?
  isRead        Boolean  @default(false)
  relatedPostId String?
  created_at    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post?    @relation(fields: [relatedPostId], references: [id], onDelete: Cascade)
}

model Log {
  id         String   @id @default(uuid())
  userId     String
  brand      String
  trigger    String
  intensity  Int      @default(3)
  note       String?
  photo_url  String?
  timestamp  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Insight {
  id         String   @id @default(uuid())
  userId     String
  type       String   // e.g., "Peak Hour", "Top Trigger"
  data       Json
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WrappedReport {
  id         String   @id @default(uuid())
  userId     String
  month      Int
  year       Int
  data       Json
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  endpoint   String
  p256dh     String
  auth       String
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}
